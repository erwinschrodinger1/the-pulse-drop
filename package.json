    "@react-oauth/github": "^0.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.10",
    "expo-auth-session": "~7.0.10",
    "expo-background-task": "~1.0.10",
    "expo-constants": "~18.0.9",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.19",
    "expo-font": "~14.0.11",
